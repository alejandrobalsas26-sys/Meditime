{
  "name": "meditime-pro",
  "version": "3.0.0",
  "private": true,
  "description": "Recordatorio de medicamentos con accesibilidad y SOS de emergencia",
  "scripts": {
    "dev": "npx serve MediTime_Web",
    "build": "echo 'No bundler required – static web app' && exit 0",
    "icons": "node scripts/generate-icons.mjs",
    "validate:pwa": "node scripts/validate-pwa.mjs",
    "security:check": "node scripts/security-check.mjs",
    "test": "node --test",
    "audit": "npm audit --audit-level=moderate",
    "check": "npm run security:check && npm run validate:pwa && npm test && npm run build",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:debug": "cd android && ./gradlew.bat --no-daemon assembleDebug",
    "android:bundle": "cd android && ./gradlew.bat --no-daemon bundleRelease",
    "android:release-check": "npm run android:sync && npm run android:debug",
    "android:export-apk": "node scripts/export-debug-apk.mjs",
    "android:whatsapp-apk": "npm run android:sync && npm run android:debug && npm run android:export-apk",
    "cap:init": "npx cap init \"MediTime PRO\" com.meditime.pro --web-dir MediTime_Web",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:run:ios": "npx cap run ios",
    "cap:run:android": "npx cap run android",
    "cap:update": "npx cap update"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "capacitor-native-biometric": "^4.2.2",
    "capacitor-secure-storage-plugin": "^0.10.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "sharp": "^0.33.0"
  },
  "keywords": [
    "medicamentos",
    "recordatorio",
    "salud",
    "accesibilidad",
    "pwa",
    "capacitor"
  ],
  "author": "",
  "license": "UNLICENSED"
}
